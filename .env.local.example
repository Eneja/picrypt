# Public app URL (used for share links and Open Graph tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public (browser auth session)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only (never expose service role to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auto-approve this email as admin on sign-in (optional bootstrap)
ADMIN_EMAIL=you@example.com
